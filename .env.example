# Fine-Tuning vs RAG Demo - Environment Variables
# Copy to .env: cp .env.example .env

# --------------------------------------------------
# Ollama (local LLM server)
# --------------------------------------------------
# Default host (auto-configured in Docker Compose)
# OLLAMA_HOST=http://localhost:11434

# Model to use -- must match what you pulled in Ollama
# Default: mistral (Mistral-7B-Instruct, 7B parameters)
# Alternatives: llama3.1, gemma2, phi3
LLM_MODEL=mistral

# --------------------------------------------------
# HuggingFace Token (optional, for gated models)
# --------------------------------------------------
# HF_TOKEN=your_huggingface_token_here
