# Fine-Tuning vs RAG Demo - Environment Variables
# Copy to .env: cp .env.example .env

# --------------------------------------------------
# Ollama (local LLM server)
# --------------------------------------------------
# Default host (auto-configured in Docker Compose)
# OLLAMA_HOST=http://localhost:11434

# Base model (used for Base and RAG approaches)
# Default: llama2 (Llama2-7B)
LLM_MODEL=llama2

# Fine-tuned model (used for Fine-tuned and Hybrid approaches)
# Default: finqa-7b (FinQA-7B, imported from HuggingFace on first run)
# This is Llama2-7B fine-tuned on 8,281 FinQA examples -- same architecture, different weights
FINETUNED_LLM_MODEL=finqa-7b

# --------------------------------------------------
# HuggingFace Token (optional, for gated models)
# --------------------------------------------------
# HF_TOKEN=your_huggingface_token_here
